{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "testMatch": [
    "**/test/**/*.test.ts"
  ],
  "moduleFileExtensions": [
    "ts",
    "tsx",
    "js",
    "jsx",
    "json"
  ],
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapping": {
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^react-native-fs$": "<rootDir>/test/__mocks__/react-native-fs.ts"
  },
  "extensionsToTreatAsEsm": [
    ".ts"
  ],
  "globals": {
    "ts-jest": {
      "useESM": true
    }
  },
  "setupFilesAfterEnv": [
    "<rootDir>/test/setup.ts"
  ]
}